+    def _ck_fp8_dequantize_patched(cls, qdata, params):
+        if qdata.device.type == 'mps' or params.scale.device.type == 'mps':
+            output_dtype = params.orig_dtype
+            qdata_cpu = qdata.to(device='cpu')
+            scale_cpu = params.scale.to(device='cpu')
